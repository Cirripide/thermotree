README*
*.md
LICENSE*
Dockerfile
.dockerignore
docker-compose*.yml

# Dev-server only — replaced by nginx.conf in prod
proxy.conf.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
