# Node modules — npm ci reinstalls fresh from package-lock.json
node_modules/

# Angular caches and outputs
.angular/
dist/
coverage/

# TypeScript build info
*.tsbuildinfo

# Test artifacts
.nyc_output/

# Local config / secrets
.env
.env.local
.env.*.local

